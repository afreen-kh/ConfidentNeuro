# .env.example
# Anthropic API key for Claude models
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key for GPT models
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API key (used for benchmark construction only)
GEMINI_API_KEY=your_gemini_api_key_here

# NCBI API key for Entrez/PubMed querying
NCBI_API_KEY=your_ncbi_api_key_here

# Email required by NCBI Entrez API (any valid email)
ENTREZ_EMAIL=your_email@example.com

# HuggingFace token for Mixtral-8x7B and other open-source models
HF_TOKEN=your_huggingface_token_here
